rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() { return request.auth != null; }
    function isUser(uid)  { return isSignedIn() && request.auth.uid == uid; }

    function myRoleDoc() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data;
    }
    function hasRoleDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/user_roles/$(request.auth.uid));
    }
    function hasRole(role) {
      return hasRoleDoc() && myRoleDoc().role == role;
    }
    function hasAnyRole(roles) {
      return hasRoleDoc() && (myRoleDoc().role in roles);
    }
    function isAdmin()     { return hasRole('admin'); }
    function isEditor()    { return hasAnyRole(['admin', 'editor']); }
    function isModerator() { return hasAnyRole(['admin', 'moderator']); }
    function isRecruiter() { return hasAnyRole(['admin', 'recruiter']); }

    function isPublished() {
      return resource.data.published == true;
    }

    // ---------- user_roles (admin role assignments) ----------
    // A user can read ONLY their own role document.
    // Writes are admin-only EXCEPT the first-admin bootstrap: if the
    // user_roles collection is empty, an authenticated user may create
    // their own admin doc. We can't query collection size from rules,
    // so we restrict create to (a) admins, or (b) the user creating
    // their own doc with role == 'admin' (bootstrap). The client must
    // still verify "no admin exists" before attempting bootstrap; a
    // race here only allows one extra self-promotion before admins
    // exist, which is the intended bootstrap window.
    match /user_roles/{userId} {
      allow get: if isUser(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin()
                    || (isUser(userId)
                        && (request.resource.data.role == 'admin'
                            || request.resource.data.role == 'candidate'
                            || request.resource.data.role == 'user'));
      allow update, delete: if isAdmin();
    }

    // ---------- profiles ----------
    match /profiles/{userId} {
      allow get: if isUser(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isUser(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- site_settings (brand/config; contact info intentionally public) ----------
    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- deployments ----------
    match /deployments/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- Public CMS content (read public-published; admin writes) ----------
    match /industries/{id}   { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /services/{id}     { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /case_studies/{id} { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /posts/{id}        { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /testimonials/{id} { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /custom_pages/{id} { allow read: if isPublished() || isEditor(); allow write: if isEditor(); }
    match /page_content/{id} { allow read: if true; allow write: if isEditor(); }

    // ---------- team_members ----------
    // Public read of published profiles, but email field is sensitive.
    // Public clients should never include an `email` filter on reads; we
    // can't column-restrict in Firestore, so admins must keep email out
    // of any document whose `published == true` if it is not meant to be
    // public-facing.
    match /team_members/{id} {
      allow read: if isPublished() || isEditor();
      allow write: if isEditor();
    }

    // ---------- contact_submissions (public form; admin reads) ----------
    match /contact_submissions/{id} {
      allow create: if request.resource.data.keys().hasOnly(
                       ['name', 'email', 'phone', 'company', 'subject', 'message', 'createdAt', 'source']
                     )
                     && request.resource.data.email is string
                     && request.resource.data.message is string;
      allow read, update, delete: if isAdmin();
    }

    // ---------- Jobs ----------
    match /jobs/{jobId} {
      allow read: if (resource.data.published == true)
                  || (resource.data.status == 'published')
                  || isRecruiter() || isEditor();
      allow create, update, delete: if isRecruiter() || isEditor();
    }

    // ---------- Companies ----------
    match /companies/{companyId} {
      allow read: if true;
      allow create, update, delete: if isEditor() || isRecruiter();
    }

    // ---------- Applications ----------
    match /applications/{appId} {
      allow get: if isRecruiter()
                 || (isSignedIn()
                     && (resource.data.userId == request.auth.uid
                         || resource.data.candidate_id == request.auth.uid));
      allow list: if isRecruiter()
                  || (isSignedIn()
                      && (resource.data.userId == request.auth.uid
                          || resource.data.candidate_id == request.auth.uid));
      allow create: if isSignedIn()
                    && (request.resource.data.userId == request.auth.uid
                        || request.resource.data.candidate_id == request.auth.uid);
      // Candidates may only update cover_letter / resume_url on their own application.
      allow update: if isRecruiter()
                    || (isSignedIn()
                        && resource.data.candidate_id == request.auth.uid
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['cover_letter', 'resume_url', 'updatedAt']));
      allow delete: if isRecruiter();
    }

    // ---------- saved_jobs ----------
    match /saved_jobs/{id} {
      allow read, write: if isSignedIn()
                          && (resource.data.userId == request.auth.uid
                              || request.resource.data.userId == request.auth.uid);
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
